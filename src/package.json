{
  "name": "personal-website",
  "version": "1.0.0",
  "description": "A personal developer website for displaying projects and a simple blog using MongoDB and Node.js",
  "main": "index.js",
  "scripts": {
    "client-install": "npm install --prefix client",
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "client": "npm start --prefix client",
    "full": "concurrently \"npm run server\" \"npm run client\""
  },
  "author": "António Duarte",
  "license": "MIT",
  "dependencies": {
    "express": "^4.17.1",
    "mongoose": "^5.10.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.4"
  }
}